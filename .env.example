# Server (loopback-only by default)
HOST=127.0.0.1
PORT=7391
AUTO_OPEN_BROWSER=true

# Comma-separated extra browser origins, only when using a separate frontend
FRONTEND_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# Runtime paths
DOWNLOAD_DIR=./downloads
LOG_DIR=./logs
# YTDLP_PATH=C:/Tools/yt-dlp.exe

# Logging and process limits
LOG_LEVEL=info
MAX_CONCURRENT_DOWNLOADS=3
YTDLP_CHECK_TIMEOUT_MS=15000
INFO_TIMEOUT_MS=120000
MAX_DOWNLOAD_DURATION_MS=1800000
INFO_MAX_OUTPUT_BYTES=16777216
REQUESTS_PER_MINUTE=180
DOWNLOAD_REQUESTS_PER_MINUTE=20

# Security opt-ins. Keep these false unless the machine and every client are trusted.
ALLOW_CUSTOM_DOWNLOAD_PATH=false
ALLOW_DANGEROUS_OPTIONS=false
ALLOW_PRIVATE_URLS=false
